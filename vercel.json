{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "klye.org" }],
      "destination": "https://kylevincent.org/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.klye.org" }],
      "destination": "https://kylevincent.org/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}